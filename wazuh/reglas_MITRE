<!-- Reglas MITRE ATT&CK -->

<rule id="100001" level="10">
  <if_matched_sid>5503</if_matched_sid>
  <description>MITRE T1110 - Brute Force: Multiple authentication failures</description>
  <mitre><id>T1110</id></mitre>
</rule>

<rule id="100002" level="10">
  <if_matched_sid>5760</if_matched_sid>
  <description>MITRE T1021.004 - SSH: Remote login attempt detected</description>
  <mitre><id>T1021.004</id></mitre>
</rule>

<rule id="100003" level="8">
  <if_matched_sid>5407</if_matched_sid>
  <description>MITRE T1078 - Valid Accounts: Sudo execution detected</description>
  <mitre><id>T1078</id></mitre>
</rule>

<rule id="100004" level="12">
  <if_sid>5715</if_sid>
  <match>/etc/shadow</match>
  <description>MITRE T1003 - Credential Dumping: Access to /etc/shadow</description>
  <mitre><id>T1003</id></mitre>
</rule>

<rule id="100005" level="8">
  <if_sid>5400</if_sid>
  <match>bash|python3|perl</match>
  <description>MITRE T1059 - Command Interpreter: Script execution detected</description>
  <mitre><id>T1059</id></mitre>
</rule>

<rule id="100006" level="12">
  <if_sid>550</if_sid>
  <match>\.encrypted|\.locked|\.crypto|\.ransom</match>
  <description>MITRE T1486 - Data Encrypted: Ransomware extension detected</description>
  <mitre><id>T1486</id></mitre>
</rule>

<rule id="100007" level="10">
  <if_sid>86601</if_sid>
  <match>ET MALWARE|ET TROJAN|ET CNC</match>
  <description>MITRE T1071 - C2 Channel: Malicious traffic detected by Suricata</description>
  <mitre><id>T1071</id></mitre>
</rule>

<rule id="100008" level="8">
  <if_sid>86601</if_sid>
  <match>ET SCAN|NMAP|port scan</match>
  <description>MITRE T1046 - Network Service Scanning: Scan detected</description>
  <mitre><id>T1046</id></mitre>
</rule>

<rule id="100009" level="12">
  <if_matched_sid>5303</if_matched_sid>
  <description>MITRE T1548 - Privilege Escalation: Sudo abuse detected</description>
  <mitre><id>T1548</id></mitre>
</rule>

<rule id="100010" level="10">
  <if_sid>5901</if_sid>
  <description>MITRE T1136 - Create Account: New user created</description>
  <mitre><id>T1136</id></mitre>
</rule>

</group>
